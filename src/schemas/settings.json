{
  "$id": "Settings",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "embedding-model": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "label": {
          "type": "string",
          "default": "Embedding Model"
        },
        "description": {
          "type": "string",
          "default": "The embedding model to use."
        },
        "value": {
          "type": "string",
          "default": "Xenova/all-MiniLM-L6-v2"
        },
        "secure": {
          "type": "boolean",
          "default": false
        },
        "category": {
          "type": "string",
          "default": "general"
        }
      },
      "required": [
        "label",
        "description",
        "value",
        "secure",
        "category"
      ]
    },
    "pinecone-index": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "label": {
          "type": "string",
          "default": "Pinecone Index"
        },
        "description": {
          "type": "string",
          "default": "The Pinecone index to use for vector storage and search."
        },
        "value": {
          "type": "string",
          "default": "shs-ext"
        },
        "secure": {
          "type": "boolean",
          "default": false
        },
        "category": {
          "type": "string",
          "default": "general"
        }
      },
      "required": [
        "label",
        "description",
        "value",
        "secure",
        "category"
      ]
    },
    "pinecone-namespace": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "label": {
          "type": "string",
          "default": "Pinecone Namespace"
        },
        "description": {
          "type": "string",
          "default": "The Pinecone namespace to use for vector storage and search."
        },
        "value": {
          "type": "string",
          "default": ""
        },
        "secure": {
          "type": "boolean",
          "default": false
        },
        "category": {
          "type": "string",
          "default": "general"
        }
      },
      "required": [
        "label",
        "description",
        "value",
        "secure",
        "category"
      ]
    },
    "pinecone-api-key": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "label": {
          "type": "string",
          "default": "Pinecone API Key"
        },
        "description": {
          "type": "string",
          "default": "The Pinecone API key to use for vector storage and search."
        },
        "value": {
          "type": "string",
          "default": ""
        },
        "secure": {
          "type": "boolean",
          "default": true
        },
        "category": {
          "type": "string",
          "default": "general"
        }
      },
      "required": [
        "label",
        "description",
        "value",
        "secure",
        "category"
      ]
    },
    "include-patterns": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "label": {
          "type": "string",
          "default": "URL Include Patterns"
        },
        "description": {
          "type": "string",
          "default": "Include urls matching any of these patterns."
        },
        "value": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [
            "https://*/*",
            "http://*/*"
          ]
        },
        "secure": {
          "type": "boolean",
          "default": false
        },
        "category": {
          "type": "string",
          "default": "general"
        }
      },
      "required": [
        "label",
        "description",
        "value",
        "secure",
        "category"
      ]
    },
    "exclude-patterns": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "label": {
          "type": "string",
          "default": "URL Exclude Patterns"
        },
        "description": {
          "type": "string",
          "default": "Exclude urls matching any of these patterns."
        },
        "value": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [
            "https://*/*",
            "http://*/*"
          ]
        },
        "secure": {
          "type": "boolean",
          "default": false
        },
        "category": {
          "type": "string",
          "default": "general"
        }
      },
      "required": [
        "label",
        "description",
        "value",
        "secure",
        "category"
      ]
    },
    "history-limit-days": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "label": {
          "type": "string",
          "default": "History Limit (days)"
        },
        "description": {
          "type": "string",
          "default": "Number of days of browsing history to display."
        },
        "value": {
          "type": "number",
          "default": 90
        },
        "secure": {
          "type": "boolean",
          "default": false
        },
        "category": {
          "type": "string",
          "default": "general"
        }
      },
      "required": [
        "label",
        "description",
        "value",
        "secure",
        "category"
      ]
    },
    "search-result-limit": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "label": {
          "type": "string",
          "default": "Search Result Limit"
        },
        "description": {
          "type": "string",
          "default": "Maximum number of pages to return in search results."
        },
        "value": {
          "type": "number",
          "default": 5
        },
        "secure": {
          "type": "boolean",
          "default": false
        },
        "category": {
          "type": "string",
          "default": "general"
        }
      },
      "required": [
        "label",
        "description",
        "value",
        "secure",
        "category"
      ]
    },
    "search-similarity-threshold": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "label": {
          "type": "string",
          "default": "Search Similarity Threshold"
        },
        "description": {
          "type": "string",
          "default": "Minimum similarity score (0-1) for a result to be included. Higher values return fewer but more relevant results."
        },
        "value": {
          "type": "number",
          "default": 0
        },
        "secure": {
          "type": "boolean",
          "default": false
        },
        "category": {
          "type": "string",
          "default": "general"
        }
      },
      "required": [
        "label",
        "description",
        "value",
        "secure",
        "category"
      ]
    },
    "search-child-limit": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "label": {
          "type": "string",
          "default": "Search Child Limit"
        },
        "description": {
          "type": "string",
          "default": "Candidate chunks retrieved per search. Higher values improve recall but increase latency."
        },
        "value": {
          "type": "number",
          "default": 5000
        },
        "secure": {
          "type": "boolean",
          "default": false
        },
        "category": {
          "type": "string",
          "default": "general"
        }
      },
      "required": [
        "label",
        "description",
        "value",
        "secure",
        "category"
      ]
    },
    "search-top-k": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "label": {
          "type": "string",
          "default": "Search Top-K"
        },
        "description": {
          "type": "string",
          "default": "Top-scoring chunks averaged per result. Higher values reward pages with broad relevance."
        },
        "value": {
          "type": "number",
          "default": 3
        },
        "secure": {
          "type": "boolean",
          "default": false
        },
        "category": {
          "type": "string",
          "default": "general"
        }
      },
      "required": [
        "label",
        "description",
        "value",
        "secure",
        "category"
      ]
    },
    "search-length-penalty": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "label": {
          "type": "string",
          "default": "Search Length Penalty"
        },
        "description": {
          "type": "string",
          "default": "Length penalty for long pages (0 = none, 1 = full). Reduces bias toward long documents."
        },
        "value": {
          "type": "number",
          "default": 0.2
        },
        "secure": {
          "type": "boolean",
          "default": false
        },
        "category": {
          "type": "string",
          "default": "general"
        }
      },
      "required": [
        "label",
        "description",
        "value",
        "secure",
        "category"
      ]
    },
    "indexed-half-life": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "label": {
          "type": "string",
          "default": "Indexed Half-life (days)"
        },
        "description": {
          "type": "string",
          "default": "Number of days after which a visit to an indexed page contributes half as much to it's frecency score."
        },
        "value": {
          "type": "number",
          "default": 30
        },
        "secure": {
          "type": "boolean",
          "default": false
        }
      },
      "required": [
        "label",
        "description",
        "value",
        "secure"
      ]
    },
    "unindexed-half-life": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "label": {
          "type": "string",
          "default": "Unindexed Half-life (days)"
        },
        "description": {
          "type": "string",
          "default": "Number of days after which a visit to a non-indexed page contributes half as much to it's frecency score."
        },
        "value": {
          "type": "number",
          "default": 14
        },
        "secure": {
          "type": "boolean",
          "default": false
        }
      },
      "required": [
        "label",
        "description",
        "value",
        "secure"
      ]
    },
    "purge-threshold": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "label": {
          "type": "string",
          "default": "Purge Threshold"
        },
        "description": {
          "type": "string",
          "default": "Entries with a frecency score below this threshold are flagged for purging."
        },
        "value": {
          "type": "number",
          "default": 0.1
        },
        "secure": {
          "type": "boolean",
          "default": false
        }
      },
      "required": [
        "label",
        "description",
        "value",
        "secure"
      ]
    },
    "sync-interval": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "label": {
          "type": "string",
          "default": "Sync Interval (minutes)"
        },
        "description": {
          "type": "string",
          "default": "How often to sync with the remote sync server (1-60 minutes)."
        },
        "value": {
          "type": "number",
          "minimum": 1,
          "maximum": 60,
          "default": 5
        },
        "secure": {
          "type": "boolean",
          "default": false
        },
        "category": {
          "type": "string",
          "default": "sync"
        }
      },
      "required": [
        "label",
        "description",
        "value",
        "secure",
        "category"
      ]
    }
  }
}